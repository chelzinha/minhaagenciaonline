  Cache-Control: no-cache, no-store, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/shared/auth/agf-auth-config.js
  Cache-Control: no-cache, no-store, must-revalidate

/shared/*
  Cache-Control: public, max-age=3600, must-revalidate

/*.webmanifest
  Cache-Control: public, max-age=3600, must-revalidate

/*.css
  Cache-Control: public, max-age=3600, must-revalidate

/*.js
  Cache-Control: public, max-age=3600, must-revalidate

/reverso/*
